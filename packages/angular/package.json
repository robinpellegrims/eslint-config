{
  "name": "@pellegrims/eslint-config-angular",
  "version": "2.0.1",
  "description": "Angular shareable ESLint configuration from @pellegrims",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robinpellegrims/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/robinpellegrims/eslint-config/issues"
  },
  "homepage": "https://github.com/robinpellegrims/eslint-config#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@pellegrims/eslint-config-base": ">=2.0.1",
    "typescript-eslint": "^8.0.0"
  }
}
